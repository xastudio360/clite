# =============================================================================
# Build directories
# =============================================================================
build/
build-*/
out/
_build/
cmake-build-*/

# =============================================================================
# CMake generated files
# =============================================================================
CMakeCache.txt
CMakeFiles/
CMakeScripts/
CTestTestfile.cmake
cmake_install.cmake
install_manifest.txt
compile_commands.json
CPackConfig.cmake
CPackSourceConfig.cmake
_CPack_Packages/

# Generated CMake config files (installed artifacts, not source)
CliteConfig.cmake
CliteConfigVersion.cmake
CliteTargets.cmake
CliteTargets-*.cmake

# =============================================================================
# Meson generated files
# =============================================================================
meson-private/
meson-logs/
meson-info/
.mesonpy/

# =============================================================================
# Compiled object files and libraries
# =============================================================================
*.o
*.obj
*.lo
*.slo
*.ko

# Static libraries
*.a
*.lib

# Shared libraries
*.so
*.so.*
*.dylib
*.dll

# Executables
*.exe
*.out
*.app
*.elf
*.axf
*.hex
*.bin
*.map

# =============================================================================
# Precompiled headers
# =============================================================================
*.gch
*.pch

# =============================================================================
