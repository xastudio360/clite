# =============================================================================
*.dSYM/
*.su
*.idb
*.pdb
*.ilk
*.exp

# Profiling data
*.gcno
*.gcda
*.gcov
gmon.out
perf.data
perf.data.old

# =============================================================================
# Sanitizer / Valgrind artifacts
# =============================================================================
vgcore.*
core
core.*
*.asan
*.tsan
*.ubsan

# =============================================================================
# Code coverage
# =============================================================================
*.lcov
coverage/
coverage.info
coverage-report/
lcov.info
*.profraw
*.profdata
default.profraw

# =============================================================================
# Fuzz testing artifacts
# =============================================================================
crash-*
leak-*
timeout-*
oom-*
slow-unit-*
corpus/
artifacts/

# =============================================================================
