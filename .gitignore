# =============================================================================
*.tmp
*.temp
*.bak
*.swp
*.orig
*.rej
*.patch
*~

# =============================================================================
# Environment and secrets
# =============================================================================
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
secrets.h
secrets.c

# =============================================================================
# Dependency vendoring (keep Unity, exclude everything else fetched by CMake)
# =============================================================================
# Allow vendored Unity test framework
!tests/vendor/
# Exclude everything CMake FetchContent downloads at configure time
_deps/
